{
  "name": "poweratlas",
  "private": true,
  "version": "0.3.0",
  "packageManager": "pnpm@10.34.5",
  "scripts": {
    "dev": "pnpm --filter @poweratlas/web dev",
    "build": "pnpm --filter @poweratlas/web build",
    "preview": "pnpm --filter @poweratlas/web preview",
    "typecheck": "pnpm --filter @poweratlas/web typecheck",
    "geo": "pnpm --filter @poweratlas/web geo",
    "api-install": "cd apps/api && py -m venv .venv && .venv\\Scripts\\python.exe -m pip install -e \".[dev]\"",
    "api-dev": "cd apps/api && .venv\\Scripts\\python.exe -m uvicorn src.main:app --reload --port 8000",
    "api-test": "cd apps/api && .venv\\Scripts\\python.exe -m pytest -q",
    "api-lint": "cd apps/api && .venv\\Scripts\\python.exe -m ruff check src tests && .venv\\Scripts\\python.exe -m mypy src"
  }
}
