# PowerAtlas API (F3) environment.
# Copy to .env and adjust. All values have safe local defaults.

# Comma-separated browser origins allowed by CORS (web dev + preview).
PA_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,http://127.0.0.1:5173,http://127.0.0.1:4173

# Uvicorn bind (dev).
PA_API_HOST=0.0.0.0
PA_API_PORT=8000

# development | production | test
PA_ENVIRONMENT=development

# F5 worker (Celery). Defaults reach the dockerized redis from the host
# (`pnpm redis-up`); the compose worker service overrides the hostname.
# PA_REDIS_URL=redis://localhost:6379/0
# PA_CELERY_BROKER_URL=redis://localhost:6379/1
# PA_CELERY_RESULT_BACKEND=redis://localhost:6379/2
