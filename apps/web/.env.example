# PowerAtlas web environment.
# Copy to `.env` (or `.env.local`) to point the app at a running API.

# Base URL of the FastAPI backend (F3). Leave unset to run fully offline on
# the bundled fictional mock dataset. When set, the app loads from
# `${VITE_API_URL}/api/v1/power-data`.
# VITE_API_URL=http://localhost:8000
